[instances.docs-writer]
agent        = "worker"
ephemeral    = true
runtime      = "codex"
token_budget = "40M"
description  = "Documentation writer on the claude runtime (subscription Opus-class prose). Dispatched for README/guide/narrative work."

[[instances.docs-writer.triggers]]
event        = "agent.dispatch"
match.target = "docs-writer"

[[instances.docs-writer.triggers]]
event      = "schedule"
match.name = "docs-freshness"
match.kind = "docs_freshness"



# The docs team's freshness loop: weekly, the docs-writer audits docs against
# the shipped binary + latest release and files a stale-docs ticket (or is
# dispatched to fix directly). See the docs-freshness skill.
[schedules.docs-freshness]
every = "24h"

[schedules.docs-freshness.payload]
kind = "docs_freshness"

